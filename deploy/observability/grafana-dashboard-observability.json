{
  "dashboard": {
    "title": "Lexicon Observability",
    "panels": [
      {
        "title": "Logs (Loki)",
        "type": "logs",
        "datasource": "Loki",
        "targets": [
          { "expr": "{service=~\"intake-gateway|ocr-pipeline|fraud-detection\"}" }
        ]
      },
      {
        "title": "Traces (Tempo)",
        "type": "traces",
        "datasource": "Tempo",
        "targets": [
          { "query": "service.name = intake-gateway" }
        ]
      },
      {
        "title": "Metrics (Prometheus)",
        "type": "timeseries",
        "datasource": "Prometheus",
        "targets": [
          { "expr": "rate(documents_uploaded_total[5m])" }
        ]
      }
    ]
  }
}
